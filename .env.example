# -----------------------------
# Core Runtime
# -----------------------------
DEUNA_MERCHANT_ID=M001
APP_TIMEZONE=America/Guayaquil
APP_CURRENCY=USD
WEEK_START=MONDAY

# -----------------------------
# Dataset Build / Validation
# -----------------------------
DATASET_SEED=20260418
DATASET_MONTHS=12
DATASET_TX_PER_MERCHANT=2000
DATASET_END_DATE=2026-04-18
DATASET_MERCHANT_COUNT=3
DATA_RAW_DIR=data/raw
DATA_DUCKDB_PATH=data/duckdb/analytics.duckdb

# -----------------------------
# Eval Artifact Build
# -----------------------------
EVAL_MERCHANT_ID=M001
PROFILES_PATH=src/agent/semantics/profiles.yaml
REFINE_QUESTIONS_WITH_LLM=true
QUESTION_REFINE_MODEL=gpt-4o-mini
QUESTION_REFINE_TEMPERATURE=0.0

# -----------------------------
# Intent Routing
# -----------------------------
INTENTS_YAML_PATH=src/agent/semantics/intents.yaml
INTENT_CLASSIFIER_ENABLED=true
INTENT_CLASSIFIER_MODEL=gpt-4.1-mini
INTENT_CLASSIFIER_TEMPERATURE=0.0
INTENT_CLASSIFIER_TIMEOUT_SECONDS=5.0
INTENT_CLASSIFIER_MIN_CONFIDENCE=0.65
QUERY_REGISTRY_PATH=src/agent/semantics/query_registry.yaml
AUTO_GUARDED_SQL_FALLBACK=true

# -----------------------------
# Registry Planner
# -----------------------------
AGENT_PLANNER_MODEL=gpt-4.1-mini
AGENT_PLANNER_TEMPERATURE=0.0
AGENT_PLANNER_TIMEOUT_SECONDS=6.0
AGENT_PLANNER_MIN_CONFIDENCE=0.55

# -----------------------------
# Text-to-SQL Fallback
# -----------------------------
ENABLE_TEXT2SQL_FALLBACK=false
TEXT2SQL_MODEL=gpt-4.1-mini
TEXT2SQL_TEMPERATURE=0.0
TEXT2SQL_TIMEOUT_SECONDS=8.0
TEXT2SQL_MAX_ROWS=20

# -----------------------------
# Answer Generation Layer
# -----------------------------
ANSWER_GENERATOR_ENABLED=true
ANSWER_GENERATOR_MODEL=gpt-4.1-mini
ANSWER_GENERATOR_TEMPERATURE=0.0
ANSWER_GENERATOR_TIMEOUT_SECONDS=6.0
ANSWER_PROMPT_PATH=src/agent/prompts/generate_answer.md

# -----------------------------
# LangGraph Agent Runtime
# -----------------------------
AGENT_MODEL=gpt-4.1-mini
AGENT_TEMPERATURE=0.0
AGENT_TIMEOUT_SECONDS=12.0

# -----------------------------
# LLM / Tracing Providers
# -----------------------------
OPENAI_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hackaton-deuna
LANGSMITH_TRACING=true
